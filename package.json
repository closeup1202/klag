{
  "name": "kafka-why",
  "version": "0.1.0",
  "description": "Kafka consumer lag root cause analyzer",
  "type": "module",
  "bin": {
    "kafka-why": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
